# Biome lint + format on staged files
npx biome check --staged --no-errors-on-unmatched

# Block files larger than 5MB
MAX_SIZE=5242880
large_files=$(git diff --cached --name-only --diff-filter=d | while read -r f; do
  size=$(git cat-file -s ":$f" 2>/dev/null || echo 0)
  if [ "$size" -gt "$MAX_SIZE" ]; then
    echo "  $f ($(( size / 1024 / 1024 ))MB)"
  fi
done)
if [ -n "$large_files" ]; then
  echo "❌ Large files detected (>5MB):"
  echo "$large_files"
  echo ""
  echo "Consider using git-lfs or reducing file size."
  echo "Bypass: git commit --no-verify"
  exit 1
fi

# Block unresolved merge conflict markers
conflict_files=$(git diff --cached --name-only --diff-filter=d | while read -r f; do
  if git show ":$f" 2>/dev/null | grep -qE '^(<{7}|={7}|>{7}) '; then
    echo "  $f"
  fi
done)
if [ -n "$conflict_files" ]; then
  echo "❌ Unresolved merge conflict markers found:"
  echo "$conflict_files"
  echo ""
  echo "Resolve conflicts before committing."
  echo "Bypass: git commit --no-verify"
  exit 1
fi
